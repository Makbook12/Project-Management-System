# Copy to .env and adjust (or run: npm run setup:env from project root).

# Local dev (default — no Atlas IP whitelist; requires MongoDB running on this machine):
MONGODB_URI=mongodb://127.0.0.1:27017/project-management

# MongoDB Atlas (optional — add IP under Network Access, or 0.0.0.0/0 for dev only):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/project-management?retryWrites=true&w=majority

JWT_SECRET=change_this_to_a_long_random_string
PORT=5000
NODE_ENV=development

# Optional email (registration still works if these are unset)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=
